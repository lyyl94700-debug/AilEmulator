<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/package/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"> <!-- خلفية داكنة فخمة مثل الـ Gehup -->

    <!-- شريط العنوان العلوي -->
    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="G99 Cyber Emulator"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_margin="20dp" />

    <!-- قائمة الألعاب على شكل شبكة (Grid) مريحة للعين -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/gamesRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/txtTitle"
        android:padding="10dp"/>

    <!-- زر عائم لإضافة ألعاب جديدة من ذاكرة الهاتف -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnAddGame"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        android:backgroundTint="#00E676"
        app:srcCompat="@android:drawable/ic_input_add" />

</RelativeLayout>
